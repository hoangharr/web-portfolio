{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toward-aptis.local/data/schema/lesson.schema.json",
  "title": "APTIS Lesson",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "level", "themeIcon", "sections"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*-[0-9]{2}$" },
    "title": { "type": "string", "minLength": 1 },
    "level": { "type": "string", "minLength": 1 },
    "subtitle": { "type": "string" },
    "themeIcon": { "type": "string", "minLength": 1 },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/section" }
    }
  },
  "$defs": {
    "section": {
      "oneOf": [
        { "$ref": "#/$defs/introSection" },
        { "$ref": "#/$defs/vocabularySection" },
        { "$ref": "#/$defs/synonymsSection" },
        { "$ref": "#/$defs/grammarSection" },
        { "$ref": "#/$defs/mcqSection" },
        { "$ref": "#/$defs/dragDropSection" },
        { "$ref": "#/$defs/readingSection" },
        { "$ref": "#/$defs/writingSection" }
      ]
    },
    "baseSection": {
      "type": "object",
      "required": ["id", "type", "nav", "eyebrow", "title"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "type": { "type": "string" },
        "nav": { "enum": ["intro", "vocabulary", "grammar", "exercise", "reading", "writing"] },
        "eyebrow": { "type": "string" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "tip": { "$ref": "#/$defs/tip" }
      }
    },
    "introSection": {
      "allOf": [
        { "$ref": "#/$defs/baseSection" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "quote", "features", "image"],
          "properties": {
            "id": true,
            "type": { "const": "intro" },
            "nav": true,
            "eyebrow": true,
            "title": true,
            "description": true,
            "quote": { "type": "string" },
            "features": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["icon", "title", "description"],
                "properties": {
                  "icon": { "type": "string" },
                  "title": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            },
            "image": { "$ref": "#/$defs/image" },
            "badge": {
              "type": "object",
              "additionalProperties": false,
              "required": ["icon", "title", "text"],
              "properties": {
                "icon": { "type": "string" },
                "title": { "type": "string" },
                "text": { "type": "string" }
              }
            },
            "tip": { "$ref": "#/$defs/tip" }
          }
        }
      ]
    },
    "vocabularySection": {
      "allOf": [
        { "$ref": "#/$defs/baseSection" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "cards"],
          "properties": {
            "id": true,
            "type": { "const": "vocabulary" },
            "nav": true,
            "eyebrow": true,
            "title": true,
            "description": true,
            "cards": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/vocabularyCard" }
            },
            "tip": { "$ref": "#/$defs/tip" }
          }
        }
      ]
    },
    "synonymsSection": {
      "allOf": [
        { "$ref": "#/$defs/baseSection" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "rows"],
          "properties": {
            "id": true,
            "type": { "const": "synonyms" },
            "nav": true,
            "eyebrow": true,
            "title": true,
            "description": true,
            "rows": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["basic", "advanced"],
                "properties": {
                  "basic": { "type": "string" },
                  "advanced": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string" }
                  }
                }
              }
            },
            "practiceTasks": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["icon", "label", "text"],
                "properties": {
                  "icon": { "type": "string" },
                  "label": { "type": "string" },
                  "text": { "type": "string" }
                }
              }
            },
            "image": { "$ref": "#/$defs/image" },
            "tip": { "$ref": "#/$defs/tip" }
          }
        }
      ]
    },
    "grammarSection": {
      "allOf": [
        { "$ref": "#/$defs/baseSection" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "points"],
          "properties": {
            "id": true,
            "type": { "const": "grammar" },
            "nav": true,
            "eyebrow": true,
            "title": true,
            "description": true,
            "points": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/grammarPoint" }
            },
            "table": {
              "type": "object",
              "additionalProperties": false,
              "required": ["headers", "rows"],
              "properties": {
                "headers": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                },
                "rows": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string" }
                  }
                }
              }
            },
            "tip": { "$ref": "#/$defs/tip" }
          }
        }
      ]
    },
    "mcqSection": {
      "allOf": [
        { "$ref": "#/$defs/baseSection" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "questions"],
          "properties": {
            "id": true,
            "type": { "const": "mcq" },
            "nav": true,
            "eyebrow": true,
            "title": true,
            "description": true,
            "questions": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/mcqQuestion" }
            },
            "tip": { "$ref": "#/$defs/tip" }
          }
        }
      ]
    },
    "dragDropSection": {
      "allOf": [
        { "$ref": "#/$defs/baseSection" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "targets", "items"],
          "properties": {
            "id": true,
            "type": { "const": "drag-drop" },
            "nav": true,
            "eyebrow": true,
            "title": true,
            "description": true,
            "targets": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "label"],
                "properties": {
                  "id": { "type": "string" },
                  "label": { "type": "string" }
                }
              }
            },
            "items": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["id", "text", "match"],
                "properties": {
                  "id": { "type": "string" },
                  "text": { "type": "string" },
                  "match": { "type": "string" }
                }
              }
            },
            "tip": { "$ref": "#/$defs/tip" }
          }
        }
      ]
    },
    "readingSection": {
      "allOf": [
        { "$ref": "#/$defs/baseSection" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "passage"],
          "properties": {
            "id": true,
            "type": { "const": "reading" },
            "nav": true,
            "eyebrow": true,
            "title": true,
            "description": true,
            "passage": {
              "type": "object",
              "additionalProperties": false,
              "required": ["title", "parts", "options", "blanks"],
              "properties": {
                "title": { "type": "string" },
                "parts": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "oneOf": [
                      { "type": "string" },
                      {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["blank"],
                        "properties": { "blank": { "type": "string" } }
                      }
                    ]
                  }
                },
                "options": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                },
                "blanks": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["id", "correct"],
                    "properties": {
                      "id": { "type": "string" },
                      "correct": { "type": "string" }
                    }
                  }
                }
              }
            },
            "questions": {
              "type": "array",
              "items": { "$ref": "#/$defs/mcqQuestion" }
            },
            "tip": { "$ref": "#/$defs/tip" }
          }
        }
      ]
    },
    "writingSection": {
      "allOf": [
        { "$ref": "#/$defs/baseSection" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "prompt"],
          "properties": {
            "id": true,
            "type": { "const": "writing" },
            "nav": true,
            "eyebrow": true,
            "title": true,
            "description": true,
            "prompt": {
              "type": "object",
              "additionalProperties": false,
              "required": ["situation", "placeholder", "minWords", "maxWords"],
              "properties": {
                "situation": { "type": "string" },
                "placeholder": { "type": "string" },
                "minWords": { "type": "integer", "minimum": 0 },
                "maxWords": { "type": "integer", "minimum": 1 },
                "referenceAnswer": { "type": "string" },
                "focus": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            },
            "tip": { "$ref": "#/$defs/tip" }
          }
        }
      ]
    },
    "vocabularyCard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["term", "definition", "translation", "icon", "category"],
      "properties": {
        "term": { "type": "string" },
        "definition": { "type": "string" },
        "translation": { "type": "string" },
        "icon": { "type": "string" },
        "category": { "type": "string" },
        "badge": { "type": "string" },
        "variant": { "enum": ["default", "highlight", "primary"] }
      }
    },
    "grammarPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "icon", "function", "examples"],
      "properties": {
        "title": { "type": "string" },
        "icon": { "type": "string" },
        "function": { "type": "string" },
        "examples": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      }
    },
    "mcqQuestion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "prompt", "options", "correct"],
      "properties": {
        "id": { "type": "string" },
        "prompt": { "type": "string" },
        "options": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string" }
        },
        "correct": { "type": "integer", "minimum": 0 },
        "explanation": { "type": "string" }
      }
    },
    "tip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "text"],
      "properties": {
        "title": { "type": "string" },
        "text": { "type": "string" },
        "icon": { "type": "string", "default": "lightbulb" }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["src", "alt"],
      "properties": {
        "src": { "type": "string" },
        "alt": { "type": "string" }
      }
    }
  }
}
